# ============================================
# PLATAFORMA ACADÉMICA - Variables de Entorno
# ============================================

# Servidor
PORT=3000
NODE_ENV=development

# JWT
JWT_SECRET=tu_clave_secreta_muy_segura_cambiar_en_produccion
JWT_EXPIRES_IN=8h
JWT_RESET_EXPIRES_IN=15m

# Base de datos (SQLite en dev)
DB_PATH=./database/academic.db

# Email (Nodemailer) - Usar cuenta Gmail de prueba o Mailtrap
SMTP_HOST=smtp.mailtrap.io
SMTP_PORT=587
SMTP_USER=tu_usuario_mailtrap
SMTP_PASS=tu_password_mailtrap
EMAIL_FROM=noreply@unicatolica.edu.co
EMAIL_FROM_NAME=Plataforma Académica UniCatólica

# Frontend URL (para CORS y links en emails)
FRONTEND_URL=https://app.unicatolica.online/

# Institución
INSTITUTION_NAME=Universidad Católica
INSTITUTION_EMAIL=academico@unicatolica.edu.co
